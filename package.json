{
  "name": "caisse-desktop",
  "version": "2.0.1",
  "description": "Electron desktop client for caisse",
  "main": "main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "icons": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-icon.ps1",
    "predist": "npm run icons",
    "dist": "electron-builder --win",
    "dist:dir": "electron-builder --win --dir",
    "dist:publish": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-win.ps1 -Publish"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.caisse.desktop",
    "productName": "Caisse",
    "icon": "build/icon.png",
    "files": [
      "main.js",
      "receipt-print.js",
      "backend-launcher.js",
      "updater.js",
      "preload.js",
      "preload-auth.js",
      "auth.html",
      "auth.js",
      "package.json",
      "index.html",
      "renderer.js",
      "theme.js",
      "update-ui.js",
      "build/icon.png",
      "logo-2.png",
      ".env"
    ],
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "../caisse_api",
        "to": "caisse_api",
        "filter": ["**/*", "!node_modules/**/*"]
      },
      {
        "from": "../setup/scripts/Start-CaisseApi.ps1",
        "to": "setup/scripts/Start-CaisseApi.ps1"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "P4kiya",
        "repo": "caisse-desktop"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "runAfterFinish": true,
      "differentialPackage": false
    }
  }
}
