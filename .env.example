# API URL the desktop app calls (no trailing slash)
API_BASE_URL=http://localhost:3000

# Dossier serveur (API + setup) sur le PC client
CAISSE_HOME=C:\caisse

# Ticket de vente (format A5)
SHOP_NAME=Caisse
# Imprimer automatiquement apres chaque nouvelle vente (0 = non)
PRINT_AUTO=1
# Important : ne pas utiliser « Microsoft Print to PDF » comme imprimante par defaut.
# L app choisit automatiquement la premiere imprimante physique detectee.
# Nom exact si plusieurs imprimantes (voir Parametres Windows > Imprimantes) :
# PRINT_PRINTER=EPSON TM-T20

# --- Publishing releases (build machine only, not shipped to users) ---
# Create a token: GitHub → Settings → Developer settings → Personal access tokens
# Scopes: repo (for private repo) or public_repo
# GH_TOKEN=ghp_xxxxxxxx

# Must match package.json → build.publish.owner and .repo
# GITHUB_OWNER=P4kiya
# GITHUB_REPO=caisse-desktop
